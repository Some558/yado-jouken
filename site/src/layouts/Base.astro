---
import '../styles/global.css';
import meta from '../../../data/latest/meta.json';

interface Props {
  title: string;
  description: string;
  path: string;
  jsonLd?: object[];
}
const { title, description, path, jsonLd = [] } = Astro.props;
const site = Astro.site?.href.replace(/\/$/, '') ?? 'https://yadoshibori.com';
const canonical = `${site}${path}`;
const dataAsOf = meta.dataAsOf;

const orgLd = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'ヤドシボリ',
  url: `${site}/`,
  description: '泊まりたい条件から探す、温泉地の宿データベース。楽天トラベルの公開データを毎日自動集計。',
};
const allLd = [orgLd, ...jsonLd];
---

<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="ヤドシボリ" />
    <link rel="sitemap" href="/sitemap.xml" />
    {allLd.map((ld) => (
      <script type="application/ld+json" set:html={JSON.stringify(ld)} />
    ))}
  </head>
  <body>
    <header class="site-header">
      <div class="wrap">
        <a class="site-brand" href="/">
          <span class="logo-steam" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
          <span class="site-name">ヤドシボリ</span>
        </a>
        <nav class="site-nav" aria-label="メイン">
          <a href="/#conditions">条件から探す</a>
          <a href="/#areas">エリアから探す</a>
          <a href="/#matrix">早見表</a>
          <a href="/methodology/">データについて</a>
        </nav>
      </div>
    </header>
    <div class="pr-note">
      <div class="wrap">本サイトはアフィリエイト広告(楽天アフィリエイト)を利用しています。</div>
    </div>
    <main>
      <div class="wrap">
        <slot />
      </div>
    </main>
    <footer class="site-footer">
      <div class="wrap">
        <div class="footer-top">
          <div class="credit">
            <a href="https://developers.rakuten.com/" target="_blank" rel="noopener">Supported by Rakuten Developers</a>
          </div>
          <nav aria-label="フッター">
            <a href="/methodology/">データの取得方法</a>
            <a href="/about/">運営者情報</a>
            <a href="/disclaimer/">免責事項</a>
            <a href="/privacy/">プライバシーポリシー</a>
          </nav>
        </div>
        <p class="footer-note">
          掲載データは楽天トラベルの公開情報をAPI経由で取得し、毎日自動更新しています。料金・空室状況は変動するため、最新情報は必ずリンク先でご確認ください。
        </p>
        <div class="footer-bottom">
          <div class="footer-brand">ヤドシボリ — 泊まりたい条件から探す、温泉地の宿データベース</div>
          <div class="footer-asof">データ取得日: {dataAsOf}</div>
        </div>
      </div>
    </footer>
  </body>
</html>
