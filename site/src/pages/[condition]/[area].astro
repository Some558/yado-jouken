---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import StatsPanel from '../../components/StatsPanel.astro';
import HotelTable from '../../components/HotelTable.astro';
import OfferSlot from '../../components/OfferSlot.astro';

export async function getStaticPaths() {
  const pages = await getCollection('pages');
  return pages.map((entry) => ({
    params: { condition: entry.data.condition.slug, area: entry.data.area.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { condition, area, stats, hotels, dataAsOf, detection, listedMatchCount } = entry.data;

const condEd = await getEntry('editorial', `conditions/${condition.slug}`);
const areaEd = await getEntry('editorial', `areas/${area.slug}`);
const CondContent = condEd ? (await render(condEd)).Content : null;
const AreaContent = areaEd ? (await render(areaEd)).Content : null;

const path = `/${condition.slug}/${area.slug}/`;
const title = `${area.label}の${condition.label}の宿 ${stats.matchCount}件｜料金・レビューをデータ比較`;
const yen = (n: number | null) => (n == null ? '—' : `¥${n.toLocaleString('ja-JP')}`);
const description = `${area.label}(${area.officialName})で${condition.label}の宿は${stats.matchCount}件。最安${yen(stats.minPrice)}〜・料金中央値${yen(stats.medianPrice)}・レビュー平均${stats.reviewAvgMean ?? '—'}を毎日自動集計。${dataAsOf}時点のデータ。`;

const jsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'ホーム', item: 'https://yado-jouken.com/' },
      { '@type': 'ListItem', position: 2, name: condition.label, item: `https://yado-jouken.com/${condition.slug}/` },
      { '@type': 'ListItem', position: 3, name: area.label },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'ItemList',
    name: title,
    numberOfItems: hotels.length,
    itemListElement: hotels.map((h, i) => ({
      '@type': 'ListItem',
      position: i + 1,
      name: h.name,
    })),
  },
];
---

<Base title={title} description={description} path={path} jsonLd={jsonLd}>
  <nav class="breadcrumb">
    <a href="/">ホーム</a><span>›</span>
    <a href={`/${condition.slug}/`}>{condition.label}</a><span>›</span>
    {area.label}
  </nav>

  <h1>{area.label}の{condition.label}の宿</h1>
  <p class="lead">
    {dataAsOf}時点、{area.officialName}エリアで{condition.label}に該当する宿は
    <strong>{stats.matchCount}件</strong>
    {stats.matchRate != null && `(${stats.denominator.label}${stats.denominator.value}件の${stats.matchRate}%)`}。
    最低料金は{yen(stats.minPrice)}〜、中央値は{yen(stats.medianPrice)}です。
  </p>

  <StatsPanel stats={stats} />

  {CondContent && <div class="editorial"><CondContent /></div>}

  <h2>{condition.label}の宿一覧(レビュー順・上位{hotels.length}件)</h2>
  <HotelTable hotels={hotels} />
  {stats.matchCount > listedMatchCount && (
    <p class="data-asof">
      ※一覧は当サイト掲載施設のうちレビュー評価順の上位{hotels.length}件です。該当施設は全部で{stats.matchCount}件あります。
    </p>
  )}

  <OfferSlot placement="detail-below-table" />

  {AreaContent && (
    <>
      <h2>{area.label}エリアについて</h2>
      <div class="editorial"><AreaContent /></div>
    </>
  )}

  <div class="evidence">
    <strong>このページのデータについて</strong>
    <ul>
      <li>データ取得日: {dataAsOf}(楽天トラベルAPIから毎日自動更新)</li>
      {detection.type === 'vacant' ? (
        <li>該当判定: 空室検索の絞り込み条件({condition.label})。検索条件=チェックイン{detection.checkinDate}・1泊・大人2名</li>
      ) : (
        <li>該当判定: 楽天トラベルに登録された施設設備情報({condition.label})</li>
      )}
      <li>分母: {stats.denominator.label} {stats.denominator.value}件</li>
      <li>料金は「大人1名あたりの最低料金」で、プラン・日程により変動します</li>
      <li>詳しくは<a href="/methodology/">データの取得方法</a>を参照</li>
    </ul>
  </div>

  <h2>他のエリア・条件で探す</h2>
  <ul class="hub-list">
    <li><a href={`/${condition.slug}/`}>{condition.label}の宿を全エリアで比較 →</a></li>
    <li><a href={`/area/${area.slug}/`}>{area.label}の他の条件を見る →</a></li>
  </ul>
</Base>
