---
import { getCollection, getEntry, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import HotelTable from '../../components/HotelTable.astro';

export async function getStaticPaths() {
  const hubs = await getCollection('areaHubs');
  return hubs.map((entry) => ({
    params: { area: entry.data.area.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { area, conditions, dataAsOf, recordCount, hotels = [] } = entry.data;

const pages = await getCollection('pages');
const related = pages.filter((p) => p.data.area.slug === area.slug);
const byCond = new Map(related.map((p) => [p.data.condition.slug, p.data.stats]));

const areaEd = await getEntry('editorial', `areas/${area.slug}`);
const AreaContent = areaEd ? (await render(areaEd)).Content : null;

const path = `/area/${area.slug}/`;
const yen = (n: number | null) => (n == null ? '—' : `¥${n.toLocaleString('ja-JP')}〜`);
const title = `${area.label}の宿を条件から探す【${conditions.length}条件】`;
const description = `${area.label}(${area.officialName}・掲載${recordCount}施設)の宿を、温泉・貸切風呂・ペット同宿可など${conditions.length}の条件別にデータ比較。複数条件のAND絞り込みと並び替えにも対応。${dataAsOf}時点。`;
const heroSrc = `/images/area-${area.slug}.jpg`;
---

<Base title={title} description={description} path={path}>
  <nav class="breadcrumb">
    <a href="/">ホーム</a><span>›</span>
    <a href="/#areas">エリアから探す</a><span>›</span>
    {area.label}
  </nav>

  <section class="hero">
    <div>
      <div class="page-eyebrow" style="margin-top:0;">エリアハブ · {area.officialName}</div>
      <h1>{area.label}の宿を条件から探す</h1>
      <p class="lead">
        {area.officialName}エリア（掲載{recordCount.toLocaleString('ja-JP')}施設・{dataAsOf}時点）を条件別に集計しています。
        下の一覧では複数条件をANDで絞り込み、料金・レビューで並び替えできます。
      </p>
    </div>
    <div class="hero-photo">
      <img src={heroSrc} alt={`${area.label}のイメージ`} width="640" height="360" />
    </div>
  </section>

  {AreaContent && (
    <>
      <h2>{area.label}エリアについて</h2>
      <div class="editorial"><AreaContent /></div>
    </>
  )}

  <h2>条件から探す</h2>
  <div class="card-grid hub">
    {conditions.map((c) => {
      const st = byCond.get(c.condition);
      return (
        <a class="cond-card" href={`/${c.condition}/${area.slug}/`}>
          <div class="label">{c.label}</div>
          <div class="count">
            <span class="n">{st?.matchCount ?? '—'}</span>
            <span class="u">件</span>
          </div>
          <div class="min">最安 {yen(st?.minPrice ?? null)}</div>
        </a>
      );
    })}
  </div>

  {hotels.length > 0 && (
    <section class="hotel-explorer" id="explorer">
      <h2>{area.label}の宿を絞り込む</h2>
      <p class="lead" style="margin-top:0;">
        条件を複数選ぶと<strong>すべてに該当する宿</strong>（AND）だけが表示されます。未選択時は掲載宿をすべて表示します。
      </p>
      <div class="filter-bar" data-condition-filter>
        {conditions.map((c) => (
          <label class="filter-chip">
            <input type="checkbox" value={c.condition} />
            <span>{c.label}</span>
          </label>
        ))}
      </div>
      <HotelTable hotels={hotels} sortable={true} />
      <p class="data-asof empty-filter" data-empty-filter hidden>
        選択した条件の組み合わせに該当する宿がありません。条件を減らしてみてください。
      </p>
    </section>
  )}
</Base>

{hotels.length > 0 && (
  <script>
    const explorer = document.querySelector('.hotel-explorer');
    if (explorer) {
      const bar = explorer.querySelector('[data-condition-filter]');
      const list = explorer.querySelector('[data-hotel-list]');
      const empty = explorer.querySelector<HTMLElement>('[data-empty-filter]');
      const countEl = explorer.querySelector('[data-hotel-count]');

      function selected(): string[] {
        if (!bar) return [];
        return Array.from(bar.querySelectorAll<HTMLInputElement>('input:checked')).map((i) => i.value);
      }

      function refresh() {
        if (!list) return;
        const need = selected();
        const cards = Array.from(list.querySelectorAll<HTMLElement>('.hotel-card'));
        let shown = 0;
        for (const card of cards) {
          const flags = (card.dataset.conditions || '').split(/\s+/).filter(Boolean);
          const ok = need.every((c) => flags.includes(c));
          card.hidden = !ok;
          if (ok) shown += 1;
        }
        if (countEl) countEl.textContent = `表示 ${shown}件`;
        if (empty) empty.hidden = shown > 0;
      }

      bar?.addEventListener('change', refresh);
      refresh();
    }
  </script>
)}
