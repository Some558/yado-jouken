---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import meta from '../../../data/latest/meta.json';

const pages = await getCollection('pages');
const condHubs = (await getCollection('conditionHubs')).map((e) => e.data);
const areaHubs = (await getCollection('areaHubs')).map((e) => e.data);

const condOrder = ['onsen', 'daiyokujo', 'rotenburo', 'kashikiri-buro', 'sauna', 'breakfast', 'kinen', 'pet-ok'];
const areaOrder = ['hakone', 'kusatsu', 'atami', 'ikaho', 'nasu', 'karuizawa', 'kinosaki', 'dogo', 'beppu', 'yufuin'];
const conditions = condOrder
  .map((s) => condHubs.find((c) => c.condition.slug === s))
  .filter(Boolean) as typeof condHubs;
const areas = areaOrder
  .map((s) => areaHubs.find((a) => a.area.slug === s))
  .filter(Boolean) as typeof areaHubs;

const pageSet = new Map(pages.map((p) => [p.data.slug, p.data.stats.matchCount]));
const dataAsOf = meta.dataAsOf;
const yen = (n: number | null) => (n == null ? '—' : `¥${n.toLocaleString('ja-JP')}〜`);

const condCards = conditions.map((hub) => {
  const rows = hub.areas;
  const total = rows.reduce((s, r) => s + r.matchCount, 0);
  const mins = rows.map((r) => r.minPrice).filter((n): n is number => n != null);
  const min = mins.length ? Math.min(...mins) : null;
  return { slug: hub.condition.slug, label: hub.condition.label, total, min };
});

const areaCards = areas.map((hub) => {
  const related = pages.filter((p) => p.data.area.slug === hub.area.slug);
  const mins = related.map((p) => p.data.stats.minPrice).filter((n): n is number => n != null);
  const min = mins.length ? Math.min(...mins) : null;
  return {
    slug: hub.area.slug,
    label: hub.area.label,
    kana: hub.area.officialName,
    count: hub.recordCount,
    min,
  };
});

const title = 'ヤドシボリ｜泊まりたい条件から探す、温泉地の宿データベース';
const description = `温泉・貸切風呂・ペット同宿可など8条件×${areas.length}温泉地の宿を毎日自動集計。該当件数・料金相場・レビュー平均をデータで比較できます。${dataAsOf}更新。`;
---

<Base title={title} description={description} path="/">
  <section class="hero">
    <div>
      <div class="hero-kicker">泊まりたい条件から探す、温泉地の宿データベース</div>
      <h1 class="hero-title">条件が先にある旅を、<br />データで。</h1>
      <p class="hero-copy">
        「ペットと泊まれる温泉地はどこが充実している?」「貸切風呂の相場は箱根と草津でどう違う?」——
        楽天トラベルの公開データを毎日自動集計し、条件×温泉地の掛け合わせ{pages.length}ページで
        該当件数・料金相場・レビュー平均を比較できます。
      </p>
    </div>
    <div class="hero-photo">
      <img src="/images/hero-onsen-dusk.jpg" alt="" width="640" height="360" />
    </div>
  </section>

  <section id="matrix">
    <div class="matrix-head">
      <h2>条件 × エリア 早見表</h2>
      <span class="data-asof">セル = 該当施設数 / クリックで詳細へ · データ取得日 {dataAsOf}</span>
    </div>
    <div class="table-scroll">
      <table class="matrix">
        <thead>
          <tr>
            <th>条件＼エリア</th>
            {areas.map((a) => (
              <th><a href={`/area/${a.area.slug}/`}>{a.area.label}</a></th>
            ))}
          </tr>
        </thead>
        <tbody>
          {conditions.map((c) => {
            const counts = areas.map((a) => pageSet.get(`${c.condition.slug}--${a.area.slug}`) ?? null);
            const max = Math.max(...counts.filter((n): n is number => n != null), 0);
            return (
              <tr>
                <td><a href={`/${c.condition.slug}/`}>{c.condition.label}</a></td>
                {areas.map((a, i) => {
                  const count = counts[i];
                  return (
                    <td>
                      {count != null ? (
                        <a
                          class:list={['cell', { 'is-max': count === max && max > 0 }]}
                          href={`/${c.condition.slug}/${a.area.slug}/`}
                        >
                          <span class="n">{count}</span>
                          <span class="u">件</span>
                        </a>
                      ) : (
                        <span class="empty">—</span>
                      )}
                    </td>
                  );
                })}
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>
  </section>

  <section id="conditions">
    <h2>条件から探す</h2>
    <div class="card-grid conds">
      {condCards.map((c) => (
        <a class="cond-card" href={`/${c.slug}/`}>
          <div class="label">{c.label}</div>
          <div class="count"><span class="n">{c.total}</span><span class="u">件</span></div>
          <div class="min">最安 {yen(c.min)}</div>
        </a>
      ))}
    </div>
  </section>

  <section id="areas">
    <h2>エリアから探す</h2>
    <div class="card-grid areas">
      {areaCards.map((a) => (
        <a class="area-card" href={`/area/${a.slug}/`}>
          <div class="thumb">
            <img src={`/images/area-${a.slug}.jpg`} alt="" width="320" height="74" loading="lazy" />
          </div>
          <div class="body">
            <div class="label">{a.label}</div>
            <div class="kana">{a.kana}</div>
            <div class="count"><span class="n">{a.count}</span><span class="u">件掲載</span></div>
            <div class="min">最安 {yen(a.min)}</div>
          </div>
        </a>
      ))}
    </div>
  </section>
</Base>
