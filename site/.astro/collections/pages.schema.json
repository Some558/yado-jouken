{
  "$ref": "#/definitions/pages",
  "definitions": {
    "pages": {
      "type": "object",
      "properties": {
        "slug": {
          "type": "string",
          "pattern": "^[a-z0-9-]+--[a-z0-9-]+$"
        },
        "condition": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "label": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "slug",
            "label"
          ],
          "additionalProperties": false
        },
        "area": {
          "type": "object",
          "properties": {
            "slug": {
              "type": "string"
            },
            "label": {
              "type": "string",
              "minLength": 1
            },
            "officialName": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "slug",
            "label",
            "officialName"
          ],
          "additionalProperties": false
        },
        "dataAsOf": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "detection": {
          "type": "object",
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "vacant",
                "facility"
              ]
            },
            "checkinDate": {
              "type": "string"
            },
            "checkoutDate": {
              "type": "string"
            }
          },
          "required": [
            "type"
          ],
          "additionalProperties": false
        },
        "stats": {
          "type": "object",
          "properties": {
            "matchCount": {
              "type": "integer",
              "exclusiveMinimum": 0
            },
            "matchRate": {
              "type": [
                "number",
                "null"
              ]
            },
            "denominator": {
              "type": "object",
              "properties": {
                "type": {
                  "type": "string",
                  "enum": [
                    "area_total",
                    "listed_top"
                  ]
                },
                "value": {
                  "type": "integer",
                  "exclusiveMinimum": 0
                },
                "label": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "required": [
                "type",
                "value",
                "label"
              ],
              "additionalProperties": false
            },
            "minPrice": {
              "type": [
                "number",
                "null"
              ]
            },
            "medianPrice": {
              "type": [
                "number",
                "null"
              ]
            },
            "reviewAvgMean": {
              "type": [
                "number",
                "null"
              ]
            },
            "pricedCount": {
              "type": "integer"
            }
          },
          "required": [
            "matchCount",
            "matchRate",
            "denominator",
            "minPrice",
            "medianPrice",
            "reviewAvgMean",
            "pricedCount"
          ],
          "additionalProperties": false
        },
        "hotels": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "hotelNo": {
                "type": "number"
              },
              "name": {
                "type": "string",
                "minLength": 1
              },
              "kana": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "minCharge": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "reviewAverage": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "reviewCount": {
                "type": [
                  "number",
                  "null"
                ]
              },
              "access": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "address1": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "address2": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "infoUrl": {
                "type": "string",
                "pattern": "^https\\:\\/\\/hb\\.afl\\.rakuten\\.co\\.jp\\/"
              },
              "planUrl": {
                "type": "string",
                "pattern": "^https\\:\\/\\/hb\\.afl\\.rakuten\\.co\\.jp\\/"
              },
              "reviewUrl": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "thumbnail": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "imageUrl": {
                "type": [
                  "string",
                  "null"
                ]
              },
              "special": {
                "type": [
                  "string",
                  "null"
                ]
              }
            },
            "required": [
              "hotelNo",
              "name",
              "kana",
              "minCharge",
              "reviewAverage",
              "reviewCount",
              "access",
              "address1",
              "address2",
              "infoUrl",
              "planUrl",
              "reviewUrl",
              "thumbnail",
              "imageUrl",
              "special"
            ],
            "additionalProperties": false
          },
          "minItems": 3,
          "maxItems": 20
        },
        "listedMatchCount": {
          "type": "integer",
          "minimum": 3
        },
        "$schema": {
          "type": "string"
        }
      },
      "required": [
        "slug",
        "condition",
        "area",
        "dataAsOf",
        "detection",
        "stats",
        "hotels",
        "listedMatchCount"
      ],
      "additionalProperties": false
    }
  },
  "$schema": "http://json-schema.org/draft-07/schema#"
}