{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "yado-jouken page",
  "type": "object",
  "required": ["slug", "condition", "area", "dataAsOf", "detection", "stats", "hotels", "listedMatchCount"],
  "additionalProperties": false,
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+--[a-z0-9-]+$" },
    "condition": {
      "type": "object",
      "required": ["slug", "label"],
      "properties": { "slug": { "type": "string" }, "label": { "type": "string", "minLength": 1 } }
    },
    "area": {
      "type": "object",
      "required": ["slug", "label", "officialName"],
      "properties": {
        "slug": { "type": "string" },
        "label": { "type": "string", "minLength": 1 },
        "officialName": { "type": "string", "minLength": 1 }
      }
    },
    "dataAsOf": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "detection": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "enum": ["vacant", "facility"] },
        "checkinDate": { "type": "string" },
        "checkoutDate": { "type": "string" }
      }
    },
    "stats": {
      "type": "object",
      "required": ["matchCount", "matchRate", "denominator", "minPrice", "medianPrice"],
      "properties": {
        "matchCount": { "type": "integer", "minimum": 1 },
        "matchRate": { "type": ["number", "null"], "minimum": 0, "maximum": 100 },
        "denominator": {
          "type": "object",
          "required": ["type", "value", "label"],
          "properties": {
            "type": { "enum": ["area_total", "listed_top"] },
            "value": { "type": "integer", "minimum": 1 },
            "label": { "type": "string", "minLength": 1 }
          }
        },
        "minPrice": { "type": ["integer", "null"], "minimum": 500, "maximum": 1000000 },
        "medianPrice": { "type": ["integer", "null"], "minimum": 500, "maximum": 1000000 },
        "reviewAvgMean": { "type": ["number", "null"], "minimum": 0, "maximum": 5 },
        "pricedCount": { "type": "integer" }
      }
    },
    "hotels": {
      "type": "array",
      "minItems": 3,
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["hotelNo", "name", "infoUrl", "planUrl"],
        "properties": {
          "hotelNo": { "type": "integer" },
          "name": { "type": "string", "minLength": 1 },
          "kana": { "type": ["string", "null"] },
          "minCharge": { "type": ["integer", "null"] },
          "reviewAverage": { "type": ["number", "null"] },
          "reviewCount": { "type": ["integer", "null"] },
          "access": { "type": ["string", "null"] },
          "address1": { "type": ["string", "null"] },
          "address2": { "type": ["string", "null"] },
          "infoUrl": { "type": "string", "pattern": "^https://hb\\.afl\\.rakuten\\.co\\.jp/" },
          "planUrl": { "type": "string", "pattern": "^https://hb\\.afl\\.rakuten\\.co\\.jp/" },
          "reviewUrl": { "type": ["string", "null"] },
          "thumbnail": { "type": ["string", "null"] },
          "special": { "type": ["string", "null"] }
        }
      }
    },
    "listedMatchCount": { "type": "integer", "minimum": 3 }
  }
}
